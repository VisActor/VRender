    "@rushstack/eslint-patch": "~1.1.4",
    "canvas": "2.11.2",
    "node-fetch": "2.6.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/node-fetch": "2.6.4",
    "@vitejs/plugin-react": "3.1.0",
    "@types/jest": "^26.0.0",
    "jest": "^26.0.0",
    "jest-electron": "npm:@pixi/jest-electron@26.1.0",
    "jest-extended": "^1.2.1",
    "ts-jest": "^26.0.0",
    "eslint": "~8.18.0",
    "vite": "3.2.6",
    "typescript": "4.9.5",
    "cross-env": "^7.0.3"
  },
  "keywords": [
    "VisActor",
    "graphics",
    "renderer",
    "vrender",
    "vrender-kits"
  ],
  "homepage": "",
  "bugs": "https://github.com/VisActor/VRender/issues",
