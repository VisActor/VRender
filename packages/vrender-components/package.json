    "@internal/ts-config": "workspace:*",
    "@rushstack/eslint-patch": "~1.1.4",
    "@visactor/vscale": "~1.0.12",
    "@types/jest": "^26.0.0",
    "jest": "^26.0.0",
    "jest-electron": "npm:@pixi/jest-electron@26.1.0",
    "ts-jest": "^26.0.0",
    "lil-gui": "^0.17.0",
    "eslint": "~8.18.0",
    "vite": "3.2.6",
    "typescript": "4.9.5",
    "cross-env": "^7.0.3"
  },
  "keywords": [
    "VisActor",
    "graphics",
    "renderer",
    "react",
    "react-vrender",
    "vrender",
    "components",
    "vrender-components"
  ],
  "homepage": "",
  "bugs": "https://github.com/VisActor/VRender/issues",
