      "label/*": ["es/label/*"],
      "legend/*": ["es/legend/*"],
      "marker": ["es/marker/index.d.ts"],
      "marker/*": ["es/marker/*"],
      "player": ["es/player/index.d.ts"],
      "player/*": ["es/player/*"],
      "poptip": ["es/poptip/index.d.ts"],
      "poptip/*": ["es/poptip/*"],
