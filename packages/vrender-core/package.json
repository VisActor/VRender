{
  "name": "@visactor/vrender-core",
  "version": "1.1.4",
  "description": "",
  "sideEffects": [
    "./src/modules.ts",
    "./cjs/modules.js",
    "./es/modules.js"
  ],
  "main": "cjs/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "typesVersions": {
    "*": {
      "application": ["es/application.d.ts"],
      "color-string": ["es/color-string/index.d.ts"],
      "common/diff": ["es/common/diff.d.ts"],
      "common/generator": ["es/common/generator.d.ts"],
      "common/performance-raf": ["es/common/performance-raf.d.ts"],
      "constants": ["es/constants.d.ts"],
      "container": ["es/container.d.ts"],
      "entries/browser": ["es/entries/browser.d.ts"],
      "entries/runtime-installer": ["es/entries/runtime-installer.d.ts"],
      "env": ["es/env.d.ts"],
      "event/constant": ["es/event/public-constant.d.ts"],
      "global": ["es/global.d.ts"],
      "graphic/base": ["es/graphic/base.d.ts"],
      "graphic/builtin-symbol": ["es/graphic/builtin-symbol.d.ts"],
      "graphic/creator": ["es/graphic/creator.d.ts"],
      "graphic/graphic-registry": ["es/graphic/graphic-registry.d.ts"],
      "graphic/group": ["es/graphic/group.d.ts"],
      "graphic/modules": ["es/graphic/modules.d.ts"],
      "graphic/symbol": ["es/graphic/symbol.d.ts"],
      "interpolate": ["es/interpolate.d.ts"],
      "legacy/bootstrap": ["es/legacy/bootstrap.d.ts"],
      "path": ["es/path.d.ts"],
      "picker/constants": ["es/picker/constants.d.ts"],
      "plugin/3d": ["es/plugin/3d.d.ts"],
      "plugin/attribute": ["es/plugin/attribute.d.ts"],
      "plugin/flex-layout": ["es/plugin/flex-layout.d.ts"],
      "register/graphic": ["es/register/graphic.d.ts"],
      "render/draw-interceptor": ["es/render/contributions/render/draw-interceptor.d.ts"],
      "render/symbol": ["es/render/contributions/render/symbol.d.ts"],
      "svg": ["es/svg.d.ts"],
      "text": ["es/text.d.ts"]
    }
  },
  "files": [
    "cjs",
    "es",
    "dist"
  ],
  "scripts": {
    "compile": "tsc --noEmit",
    "eslint": "eslint --debug --fix src/",
    "build": "cross-env DEBUG='Bundler*' bundle --clean",
    "build-umd": "cross-env DEBUG='Bundler*' bundle --clean -f umd",
    "dev": "cross-env DEBUG='Bundler*' bundle --clean -f es -w",
    "start": "vite ./__tests__/browser",
    "test": "jest -c jest.config.js",
    "test:electron": "jest -c jest.electron.config.js --runInBand --passWithNoTests --testPathPattern='__tests__/(browser|electron)/'",
    "test-live": "npm run test-watch __tests__/unit/theme/line.test.ts",
    "test-watch": "cross-env DEBUG_MODE=1 jest --watch -c jest.config.js",
    "test-cov": "jest -c jest.config.js -w 16 --coverage",
    "build:spec-types": "rm -rf ./spec-types && tsc -p ./tsconfig.spec.json --declaration --emitDeclarationOnly --outDir ./spec-types"
  },
  "dependencies": {
    "color-convert": "2.0.1",
    "@visactor/vutils": "~1.0.12"
  },
  "devDependencies": {
    "@internal/bundler": "workspace:*",
    "@internal/eslint-config": "workspace:*",
    "@internal/ts-config": "workspace:*",
    "@rushstack/eslint-patch": "~1.1.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "3.1.0",
    "@types/jest": "^26.0.0",
    "jest": "^26.0.0",
    "jest-electron": "npm:@pixi/jest-electron@26.1.0",
    "jest-extended": "^1.2.1",
    "ts-jest": "^26.0.0",
    "eslint": "~8.18.0",
    "vite": "3.2.6",
    "typescript": "4.9.5",
    "cross-env": "^7.0.3"
  },
  "keywords": [
    "VisActor",
    "graphics",
    "renderer",
    "vrender-core"
  ],
  "homepage": "",
  "bugs": "https://github.com/VisActor/VRender/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisActor/VRender.git",
    "directory": "packages/vrender-core"
  },
  "author": {
    "name": "VisActor",
    "url": "https://VisActor.io/"
  },
  "license": "MIT",
